# ===== ebk pipeline config -- copy to .env and fill in =====

# --- Phase 0: data source (REQUIRED to pull any leads) ---
# Google Cloud Console -> enable "Places API (New)" -> create key.
# Lock the key to the Mac mini's IP. Set a budget cap + quota so it cannot bill you.
GOOGLE_PLACES_KEY=

# --- AWS RDS Postgres (source of truth) ---
RDS_HOST=your-instance.xxxxxx.us-west-2.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=ebk
RDS_USER=ebk_app
RDS_PASSWORD=
RDS_SSL=true

# --- Engine (Mac mini #1) ---
ENGINE_PORT=8080

# --- Concierge AI (DGX) -- optional, off critical path ---
CONCIERGE_PORT=8090
MODEL_BASE_URL=http://localhost:11434
MODEL_NAME=llama3.1:8b
